const enterChina = [
  { label: 'Market Entry Consulting', desc: 'Strategy, business model and partner selection before launch.', href: '/enter-china/market-entry-consulting', svg: icon.compass },
  { label: 'Cross-Border eCommerce Setup', desc: 'Tmall Global and JD Worldwide. No Chinese entity needed.', href: '/enter-china/cross-border-setup', svg: icon.store },
  { label: 'Distribution', desc: 'Find the right distributor for your category and channel.', href: '/enter-china/distribution', svg: icon.truck },
  { label: 'Branding & Localisation', desc: 'Your brand, sharpened for the Chinese consumer.', href: '/enter-china/branding-localisation', svg: icon.tag },
];

const growChina = [
  { label: 'Cross-Border eCommerce', desc: 'Run your Tmall Global and JD Worldwide stores end-to-end.', href: '/grow-in-china/cross-border-ecommerce', svg: icon.bag },
  { label: 'Social Commerce', desc: 'Sales on Douyin, WeChat and RED. Livestream and KOL.', href: '/grow-in-china/social-commerce', svg: icon.chat },
  { label: 'Distribution', desc: 'B2B into retail, B2C and DTC into online and offline.', href: '/grow-in-china/distribution', svg: icon.network },
  { label: 'Media', desc: 'Performance and brand media across Chinese platforms.', href: '/grow-in-china/media', svg: icon.broadcast },
  { label: 'Website', desc: 'Sites built to load fast inside the Great Firewall.', href: '/grow-in-china/website', svg: icon.monitor },
];

const learnChina = [
  { label: 'Platforms', desc: 'Tmall, JD, Douyin, WeChat, RED, Pinduoduo. How each one works and who it is for.', href: '/learn-china/platforms', svg: icon.grid },
  { label: 'Masterclass', desc: 'Workshops led by people who run China every day.', href: '/learn-china/masterclass', svg: icon.cap },
  { label: 'Learning Expeditions', desc: 'On-the-ground programmes in Shanghai and beyond.', href: '/learn-china/learning-expeditions', svg: icon.pin },
  { label: 'Insights', desc: 'Articles, reports and analysis from the frontlines.', href: '/insights', svg: icon.bulb },
];

const sections = [
  { key: 'enter', label: 'Enter China', href: '/enter-china', intro: 'Launch in China with the right model, the right partner, the right plan.', items: enterChina },
  { key: 'grow', label: 'Grow in China', href: '/grow-in-china', intro: 'Operations, media and creative. One team running your stores, your channels, your brand.', items: growChina },
  { key: 'learn', label: 'Learn China', href: '/learn-china', intro: 'Understand the market before you bet on it. Programmes built by people who run China every day.', items: learnChina },
];
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="Beyond Border Group Home">
      <picture>
        <source srcset="/Images/Logo.webp" type="image/webp" />
        <img src="/Images/Logo.jpg" alt="Beyond Border Group" width="645" height="781" />
      </picture>
    </a>

    <nav class="nav__primary" aria-label="Primary">
      <ul class="nav__links">
        {sections.map(section => (
          <li class="nav__item nav__item--mega">
            <a href={section.href} class="nav__link" aria-haspopup="true">{section.label}</a>
            <div class="mega" role="menu" aria-label={section.label}>
              <div class="container mega__inner">
                <div class="mega__head">
                  <span class="mega__eyebrow">{section.label}</span>
                  <p class="mega__intro">{section.intro}</p>
                  <a href={section.href} class="btn btn--ghost mega__cta">All {section.label.toLowerCase()} services</a>
                </div>
                <div class={`mega__grid ${section.items.length > 3 ? 'mega__grid--6' : 'mega__grid--3'}`}>
                  {section.items.map(item => (
                    <a href={item.href} class="mega-item">
                      <span class="mega-item__icon" set:html={item.svg} />
                      <span class="mega-item__body">
                        <span class="mega-item__title">{item.label}</span>
                        <span class="mega-item__desc">{item.desc}</span>
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </li>
        ))}

        <li class="nav__item">
          <a href="/work" class="nav__link">Our Work</a>
        </li>
        <li class="nav__item">
          <a href="/about" class="nav__link">Who We Are</a>
        </li>
      </ul>
    </nav>

    <div class="nav__right">
      <a href="/contact" class="btn btn--primary btn--sm">Contact</a>
      <button class="nav__burger" type="button" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const nav = document.getElementById('site-nav');
    const onScroll = () => nav.classList.toggle('nav--scrolled', window.scrollY > 4);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    const burger = nav.querySelector('.nav__burger');
    burger?.addEventListener('click', () => {
      const open = nav.classList.toggle('nav--open');
      burger.setAttribute('aria-expanded', String(open));
    });
  })();
</script>
