---
import Layout from '../../layouts/Layout.astro';

const stats = [
  {
    value: '1.12B',
    label: 'Internet users in China',
    source: 'State Council of China, June 2025',
  },
  {
    value: '700M',
    label: "JD's annual active customers",
    source: 'JD.com, October 2025',
  },
  {
    value: '¥1T',
    label: 'China instant retail in 2025',
    source: 'China e-Commerce Platforms 2025, BBG',
  },
];

const filters = [
  {
    n: '01',
    title: 'Trust is the first filter',
    body:
      'The market is crowded and very uneven. Some candidates bring real warehouse capacity, active retail relationships and a working Tmall team. Others bring a nice pitch and not much behind it. Brands coming in cold through Alibaba listings or trade shows tend to meet more of the second kind than the first. We have spent over 15 years running this filter, in beauty, food and beverage, wellness and premium lifestyle.',
  },
  {
    n: '02',
    title: 'Offline, online, or both',
    body:
      'A distributor in China is not just a retail partner anymore. The ones worth working with run offline and online at the same time. Hema, Yonghui, RT-Mart and Watsons on the shelf side. Tmall, JD, Douyin and Xiaohongshu on the platform side. Category, SKU count, price point and target city tier all decide the profile you need.',
  },
  {
    n: '03',
    title: 'Adapting products for the shelf',
    body:
      'Almost every imported product needs work before it ships. Chinese labels on packaging. Local regulatory clearance, which changes by category: NMPA for cosmetics, SAMR for food and supplements, separate regimes for medical devices. Pack sizes that shrink for tier-1 apartment kitchens, or grow for tier-3 family formats. This work happens before the distributor signs, not after.',
  },
  {
    n: '04',
    title: 'The long game',
    body:
      'Signing a distributor is the beginning, not the finish line. Brands that disappear after the contract get pushed to the back of the shelf within two quarters. We have seen it happen in one. Brands that show up, review the numbers every month and put something behind joint trade marketing tend to stay front of store. We cover this layer when you do not have the headcount in China to do it yourself.',
  },
];

const offlineChains = [
  { en: 'Hema', cn: '盒马', sub: "Alibaba's fresh-grocery format" },
  { en: 'Yonghui', cn: '永辉', sub: 'National supermarket chain' },
  { en: 'RT-Mart', cn: '大润发', sub: 'Hypermarket leader' },
  { en: 'CR Vanguard', cn: '华润万家', sub: 'China Resources retail' },
  { en: 'Watsons', cn: '屈臣氏', sub: 'Health and beauty chain' },
];

const onlinePlatforms = [
  { en: 'Tmall', cn: '天猫', logo: '/Images/platforms/tmall-logo.svg' },
  { en: 'JD', cn: '京东', logo: '/Images/platforms/jd-logo.png' },
  { en: 'Douyin', cn: '抖音', logo: '/Images/platforms/douyin-logo.svg' },
  { en: 'Xiaohongshu', cn: '小红书', logo: '/Images/platforms/rednote-logo.svg' },
  { en: 'WeChat', cn: '微信', logo: '/Images/platforms/wechat-logo.svg' },
];

const setups = [
  {
    tag: 'Setup A',
    title: 'The distributor runs marketing',
    body:
      'Most Chinese distributors have in-house teams for content, social, KOL seeding and platform campaigns. Some beauty and FMCG distributors are genuinely excellent, with Douyin operators and Xiaohongshu seeding teams that rival any agency. Others focus narrowly on sell-through and let brand equity slide.',
    costLabel: 'Typical cost',
    costValue: '3% to 8% of net sales',
    costNote: 'Marketing contribution clause in the contract, sometimes matched by the brand. Lower out-of-pocket, less brand control.',
  },
  {
    tag: 'Setup B',
    title: 'An agency runs marketing',
    body:
      'The distributor handles sales, logistics and platform operations. An agency like us runs the brand side: content, social, media, KOLs and KOCs, campaign planning around 11.11 and 6.18, Xiaohongshu seeding, Douyin paid, WeChat CRM.',
    costLabel: 'Typical cost',
    costValue: 'RMB 40k to 150k / month',
    costNote: 'Agency fees, plus media and production budget on top. Higher out-of-pocket. Full control over positioning, consistency and long-term equity.',
    highlight: true,
  },
  {
    tag: 'Setup C',
    title: 'Hybrid',
    body:
      'Distributor covers platform basics and trade marketing. Agency handles brand building, campaign creative and KOL strategy. Most brands between €5M and €50M in China revenue end up here, in our experience.',
    costLabel: 'Where most land',
    costValue: 'Split investment',
    costNote: 'Distributor contribution on trade and operations, agency retainer on brand and creative. Balanced control, balanced cost.',
  },
];

const services = [
  {
    icon: 'search',
    title: 'Distributor sourcing',
    desc: 'Network access, longlist of 8 to 12 qualified candidates, shortlist interviews, due diligence on financials, licenses and platform track record. Six to ten weeks, sometimes longer depending on category.',
  },
  {
    icon: 'pen',
    title: 'Contract negotiation',
    desc: 'Territory, exclusivity, pricing, payment terms, MOQ, marketing contribution, brand protection, termination. We have drafted enough of these to know where the real fight happens.',
  },
  {
    icon: 'shield',
    title: 'Brand guardian',
    desc: 'Pricing enforcement across channels, consistent branding on platforms and in stores, customer service oversight. Monthly retainer, quietly keeping the brand intact.',
  },
  {
    icon: 'tag',
    title: 'Shelf and platform promotion',
    desc: 'Trade marketing planning with the distributor, platform campaign calendar, regular business reviews to keep your products front of store and high on search.',
  },
  {
    icon: 'chart',
    title: 'Data and consumer insights',
    desc: 'Monthly sell-through reporting, platform analytics, social listening, competitive benchmarking. What is working, what is not, and what needs a decision next week.',
  },
];

const models = [
  {
    name: 'Marketing agency',
    desc: 'We run brand communication in China. Social, advertising, media, KOLs and campaigns. The distributor handles the trade side.',
    bullets: [
      'Social, content and media on Tmall, JD, Douyin, RED, WeChat',
      'KOL and KOC programs, livestream campaigns',
      '11.11 and 6.18 campaign planning and execution',
    ],
    pricing: 'Scope-based, usually RMB 40,000 to 150,000 / month',
    highlight: false,
  },
  {
    name: 'Sales agent',
    desc: 'We find and manage your distributor, act as your brand guardian, and serve as your single point of contact for China operations.',
    bullets: [
      'Distributor sourcing, vetting and contract negotiation',
      'Pricing and brand consistency enforcement across channels',
      'Monthly business reviews and joint trade marketing',
    ],
    pricing: 'Monthly fixed fee plus commission on sales',
    highlight: true,
  },
  {
    name: 'Exclusive distributor',
    desc: 'We act as the master exclusive distributor for China. We buy and hold inventory and own the full P&L.',
    bullets: [
      'Marketing, sales, logistics and inventory management',
      'Online and offline distribution, direct and indirect',
      'Single point of accountability for the China business',
    ],
    pricing: 'Growth margin on products',
    highlight: false,
  },
];

const steps = [
  {
    n: '01',
    title: 'Scoping',
    time: '1 week',
    desc: 'Category, positioning, volumes, margins, China objective. We leave this meeting with a clear brief.',
  },
  {
    n: '02',
    title: 'Longlist',
    time: '2 to 3 weeks',
    desc: '8 to 12 qualified distributors from our network, matched to your category and channel mix.',
  },
  {
    n: '03',
    title: 'Shortlist and interviews',
    time: '2 weeks',
    desc: 'We narrow to three to five candidates. We run the calls with you, translate where needed, compare offers.',
  },
  {
    n: '04',
    title: 'Due diligence',
    time: '1 to 2 weeks',
    desc: 'Financials, license check, references, platform track record, warehouse and logistics setup.',
  },
  {
    n: '05',
    title: 'Negotiation',
    time: 'Variable',
    desc: 'Terms, pricing, territory, exclusivity, marketing contribution, MOQ, payment conditions.',
  },
  {
    n: '06',
    title: 'Handover',
    time: 'Ongoing',
    desc: 'Once signed, we step back. Or we stay on as your marketing agency or brand guardian. Your call.',
  },
];

const faqs = [
  {
    q: "What is the first real decision?",
    a: 'Distributor versus your own operation. Everything else follows from that one call.',
  },
  {
    q: 'Which cities matter most?',
    a: 'Depends on the category. Beauty often starts in Shanghai, Beijing and Guangzhou. Premium F&B adds Chengdu and Hangzhou. Mass-market FMCG goes broad through regional distributors across tier-2 and tier-3 cities. We work this through during scoping.',
  },
  {
    q: 'How long from first meeting to signed distributor?',
    a: 'Three to five months. Sometimes faster. Brands that take longer usually got stuck in regulatory work they should have started earlier.',
  },
  {
    q: 'Will one distributor cover all of China?',
    a: 'Sometimes. More often you end up with two or three, split by channel (offline vs online) or by region. Exclusivity clauses get negotiated carefully, because this is where first-year deals go wrong.',
  },
  {
    q: 'Who handles NMPA or SAMR registration?',
    a: 'Depends on the setup. A distributor can register under their own license, which is faster but ties you to them. You can also register under your own Chinese entity, which takes longer but keeps you portable.',
  },
  {
    q: 'What is the typical margin structure?',
    a: 'Margins vary a lot by category. Beauty can run 40% to 60%. F&B often sits at 25% to 40%. Premium hardware closer to 20%. We benchmark against your category during negotiation.',
  },
  {
    q: 'Can we terminate if it does not work?',
    a: "Yes, if the contract is written properly. Termination clauses, performance milestones and exit conditions are where most first-draft contracts are weak. We fix this upfront.",
  },
  {
    q: 'What does marketing cost in year one?',
    a: 'Rough range: RMB 500,000 for a validation-stage brand on Tmall Global. RMB 3M to 8M for a serious CBEC push with KOLs. RMB 10M and up for a full domestic launch with offline activation. We build the number with you.',
  },
  {
    q: 'Do we need to visit China?',
    a: 'Yes. At least once for the shortlist interviews, once more for the signing, and ideally one market tour per year after that. We organise the schedule.',
  },
  {
    q: 'What happens if the distributor underperforms?',
    a: 'We flag it early through monthly reviews. If the numbers do not recover, we run a replacement sourcing. Brands that wait too long on a weak partner lose more than brands that change.',
  },
];

const icons: Record<string, string> = {
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="6.5"/><path d="m20 20-4.2-4.2"/></svg>`,
  pen: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4l6 6L8 22H2v-6L14 4z"/><path d="m13 5 6 6"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 4 6v6c0 5 3.5 8.5 8 9 4.5-.5 8-4 8-9V6l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>`,
  tag: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12V3h9l9 9-9 9-9-9z"/><circle cx="7.5" cy="7.5" r="1.25"/></svg>`,
  chart: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><rect x="5" y="12" width="3" height="7"/><rect x="11" y="7" width="3" height="12"/><rect x="17" y="3" width="3" height="16"/></svg>`,
};
---

<Layout
  title="Product Distribution in China | Beyond Border Group"
  description="Find the right distributor in China, online and offline. We source, vet, negotiate, and run the marketing behind it. 15+ years on the ground."
>
  <article class="dist">

    {/* ---------- HERO ---------- */}
    <section class="dist-hero">
      <div class="dist-hero__bg" aria-hidden="true">
        <img src="/Images/insights/how-to-find-a-distributor-for-your-products-in-china-in-2024.png" alt="" />
      </div>
      <div class="dist-hero__overlay" aria-hidden="true"></div>

      <div class="container dist-hero__inner">
        <nav class="dist-hero__crumbs" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/#services">Enter China</a>
        </nav>
        <span class="eyebrow eyebrow--on-dark">Distribution in China</span>
        <h1 class="dist-hero__title">The right distributor, online and offline. And the marketing that makes it work.</h1>
        <p class="dist-hero__lead">
          We find, vet and contract the distributors who can actually move your product
          in China. Then we decide together who runs the marketing behind them, them or us.
        </p>
        <div class="dist-hero__actions">
          <a href="/contact" class="btn btn--primary">Talk to us</a>
          <a href="#how-it-works" class="btn btn--ghost-light">See how it works</a>
        </div>
      </div>
    </section>

    {/* ---------- STATS STRIP ---------- */}
    <section class="dist-stats">
      <div class="container">
        <ul class="dist-stats__grid" role="list">
          {stats.map((s) => (
            <li class="dist-stats__item">
              <span class="dist-stats__value">{s.value}</span>
              <span class="dist-stats__label">{s.label}</span>
              <span class="dist-stats__source">Source: {s.source}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    {/* ---------- INTRO ---------- */}
    <section class="section">
      <div class="container">
        <div class="dist-intro">
          <div class="dist-intro__copy">
            <span class="eyebrow">The setup</span>
            <h2>Most foreign brands enter China through a distributor.</h2>
            <p>
              It is faster than setting up your own entity, cheaper than running your own
              stores, and it puts someone with local licenses, warehouse space and retail
              contacts between your brand and the market.
            </p>
            <p>
              Picking the right one is the hard part. Knowing what to do once the contract
              is signed, even harder.
            </p>
            <p>
              China's retail market sits on a massive base. The distributors worth signing
              already operate across all of it. The rest are still catching up.
            </p>
          </div>
          <aside class="dist-intro__pull">
            <span class="dist-intro__quote-mark" aria-hidden="true">“</span>
            <p>
              The distributors worth signing already operate across all of China.
              The rest are still catching up.
            </p>
          </aside>
        </div>
      </div>
    </section>

    {/* ---------- FINDING THE RIGHT DISTRIBUTOR ---------- */}
    <section class="section section--alt">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">Finding the right distributor</span>
          <h2>Four filters we run on every shortlist</h2>
          <p class="section-header__lead">
            After 15 years running this process across beauty, F&B, wellness and premium
            lifestyle, the candidates that survive these four filters are the ones who deliver.
          </p>
        </header>

        <div class="dist-filters">
          {filters.map((f) => (
            <article class="dist-filter">
              <span class="dist-filter__n" aria-hidden="true">{f.n}</span>
              <h3 class="dist-filter__title">{f.title}</h3>
              <p class="dist-filter__body">{f.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- WHERE THEY SELL ---------- */}
    <section class="section">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">Where they sell</span>
          <h2>The right distributor runs offline and online at the same time.</h2>
          <p class="section-header__lead">
            Some focus on one side only. A food and beverage distributor might be 90%
            offline with a small WeChat store bolted on. A digital-native beauty distributor
            might never touch a physical shelf. We match the profile to your category.
          </p>
        </header>

        <div class="dist-channels">
          <div class="dist-channels__column">
            <div class="dist-channels__head">
              <span class="dist-channels__tag dist-channels__tag--offline">Offline</span>
              <h3>On the shelf</h3>
              <p>National chains, regional supermarkets and specialty retailers across tier-1 to tier-3 cities.</p>
            </div>
            <div class="dist-chains">
              {offlineChains.map((c) => (
                <div class="dist-chain">
                  <span class="dist-chain__cn" lang="zh-Hans">{c.cn}</span>
                  <div class="dist-chain__meta">
                    <span class="dist-chain__en">{c.en}</span>
                    <span class="dist-chain__sub">{c.sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-channels__column">
            <div class="dist-channels__head">
              <span class="dist-channels__tag dist-channels__tag--online">Online</span>
              <h3>On the platform</h3>
              <p>Marketplace flagships, social commerce, livestream channels and private-traffic stores.</p>
            </div>
            <div class="dist-platforms">
              {onlinePlatforms.map((p) => (
                <div class="dist-platform">
                  <div class="dist-platform__logo">
                    <img src={p.logo} alt={`${p.en} logo`} loading="lazy" decoding="async" />
                  </div>
                  <span class="dist-platform__en">{p.en}</span>
                  <span class="dist-platform__cn" lang="zh-Hans">{p.cn}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ---------- WHO RUNS MARKETING ---------- */}
    <section class="section section--alt">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">Who runs the marketing</span>
          <h2>This is the conversation to have before signing, not after.</h2>
          <p class="section-header__lead">
            Three setups, three cost profiles, three control levels. We walk the split
            with you with real numbers, both sides, before any contract is signed.
          </p>
        </header>

        <div class="dist-setups">
          {setups.map((s) => (
            <article class={`dist-setup${s.highlight ? ' dist-setup--highlight' : ''}`}>
              {s.highlight && <span class="dist-setup__badge">Most balanced</span>}
              <span class="dist-setup__tag">{s.tag}</span>
              <h3 class="dist-setup__title">{s.title}</h3>
              <p class="dist-setup__body">{s.body}</p>
              <div class="dist-setup__cost">
                <span class="dist-setup__cost-label">{s.costLabel}</span>
                <span class="dist-setup__cost-value">{s.costValue}</span>
                <p class="dist-setup__cost-note">{s.costNote}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- SERVICES ---------- */}
    <section class="section">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">Our services</span>
          <h2>Five services that cover the full distributor lifecycle</h2>
          <p class="section-header__lead">
            From sourcing the longlist to defending the brand once the contract is signed.
            We pick up the pieces you do not want to run from headquarters.
          </p>
        </header>

        <div class="dist-services">
          {services.map((s) => (
            <article class="dist-service">
              <span class="dist-service__icon" set:html={icons[s.icon]} />
              <h3 class="dist-service__title">{s.title}</h3>
              <p class="dist-service__desc">{s.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- BUSINESS MODELS ---------- */}
    <section class="section section--alt">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">Business models</span>
          <h2>Three ways to work with us</h2>
          <p class="section-header__lead">
            Pick the engagement that matches where you are today. You can move between
            them as the China business matures.
          </p>
        </header>

        <div class="dist-models">
          {models.map((m) => (
            <article class={`dist-model${m.highlight ? ' dist-model--highlight' : ''}`}>
              {m.highlight && <span class="dist-model__badge">Most popular</span>}
              <h3 class="dist-model__title">{m.name}</h3>
              <p class="dist-model__desc">{m.desc}</p>
              <ul class="dist-model__list">
                {m.bullets.map((b) => <li>{b}</li>)}
              </ul>
              <div class="dist-model__pricing">
                <span class="dist-model__pricing-label">Pricing</span>
                <span class="dist-model__pricing-value">{m.pricing}</span>
              </div>
              <a href="/contact" class="btn btn--secondary btn--sm dist-model__cta">Contact us</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- HOW IT WORKS ---------- */}
    <section id="how-it-works" class="section">
      <div class="container">
        <header class="section-header section-header--center">
          <span class="eyebrow">How it works</span>
          <h2>Six steps from first meeting to signed contract</h2>
          <p class="section-header__lead">
            Three to five months on average. Faster if your category is straightforward,
            longer if regulatory work needs to start in parallel.
          </p>
        </header>

        <ol class="dist-steps">
          {steps.map((s, i) => (
            <li class="dist-step">
              <div class="dist-step__rail" aria-hidden="true">
                <span class="dist-step__dot"></span>
                {i < steps.length - 1 && <span class="dist-step__line"></span>}
              </div>
              <div class="dist-step__body">
                <div class="dist-step__head">
                  <span class="dist-step__n">{s.n}</span>
                  <h3 class="dist-step__title">{s.title}</h3>
                  <span class="dist-step__time">{s.time}</span>
                </div>
                <p class="dist-step__desc">{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* ---------- FAQ ---------- */}
    <section class="section section--alt">
      <div class="container container--narrow">
        <header class="section-header section-header--center">
          <span class="eyebrow">FAQ</span>
          <h2>Frequently asked questions about distribution in China</h2>
        </header>

        <div class="dist-faq">
          {faqs.map((f, i) => (
            <details class="dist-faq__item" open={i === 0}>
              <summary class="dist-faq__q">
                <span>{f.q}</span>
                <span class="dist-faq__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </summary>
              <div class="dist-faq__a">
                <p>{f.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ---------- FINAL CTA ---------- */}
    <section class="section section--tight">
      <div class="container container--narrow">
        <div class="dist-cta">
          <span class="eyebrow eyebrow--on-dark">Let's talk</span>
          <h2 class="dist-cta__title">Want to talk about your category?</h2>
          <p class="dist-cta__lead">
            Tell us where you are today and where you want to be. Real humans on our side,
            no funnel, no forms that never get read.
          </p>
          <div class="dist-cta__actions">
            <a href="/contact" class="btn dist-cta__btn-primary">Contact us</a>
            <a href="/work" class="btn dist-cta__btn-ghost">See our case studies</a>
          </div>
        </div>
      </div>
    </section>
  </article>

  <style is:global>
    .dist .container--narrow { max-width: 880px; }

    /* ---------- HERO ---------- */
    .dist-hero {
      position: relative;
      min-height: clamp(520px, 64vh, 680px);
      display: flex;
      align-items: center;
      padding: clamp(96px, 12vh, 140px) 0 clamp(64px, 10vh, 120px);
      color: var(--bbg-white);
      overflow: hidden;
      isolation: isolate;
    }
    .dist-hero__bg { position: absolute; inset: 0; z-index: -2; }
    .dist-hero__bg img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
    .dist-hero__overlay {
      position: absolute; inset: 0; z-index: -1;
      background: linear-gradient(110deg,
        rgba(8, 20, 32, 0.92) 0%,
        rgba(8, 20, 32, 0.7) 45%,
        rgba(8, 20, 32, 0.35) 100%);
    }
    .dist-hero__inner { max-width: 880px; position: relative; }
    .dist-hero__crumbs {
      margin-bottom: var(--space-5);
      font-size: var(--fs-small);
      display: flex;
      gap: 0.5rem;
      align-items: center;
      color: rgba(255, 255, 255, 0.75);
    }
    .dist-hero__crumbs a { color: rgba(255, 255, 255, 0.85); font-weight: 500; }
    .dist-hero__crumbs a:hover { color: var(--bbg-white); }
    .dist-hero__inner .eyebrow--on-dark {
      display: inline-block;
      margin-bottom: var(--space-4);
      color: #9DDBF5;
    }
    .dist-hero__title {
      font-size: clamp(2.25rem, 3.6vw + 1rem, 4rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--bbg-white);
      margin: 0 0 var(--space-5);
      max-width: 22ch;
      text-wrap: balance;
    }
    .dist-hero__lead {
      font-size: clamp(1.0625rem, 0.6vw + 1rem, 1.3125rem);
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.92);
      max-width: 58ch;
      margin: 0 0 var(--space-6);
    }
    .dist-hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); }

    /* ---------- STATS STRIP ---------- */
    .dist-stats {
      background: var(--bbg-ink);
      color: var(--bbg-white);
      padding: var(--space-6) 0;
    }
    .dist-stats__grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
    }
    .dist-stats__item {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding-left: var(--space-4);
      border-left: 3px solid var(--bbg-blue);
    }
    .dist-stats__value {
      font-size: clamp(2rem, 2.4vw + 1rem, 3rem);
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.025em;
      color: var(--bbg-white);
      font-feature-settings: "tnum";
    }
    .dist-stats__label {
      font-size: 1.0625rem;
      line-height: 1.35;
      color: rgba(255, 255, 255, 0.92);
      font-weight: 500;
    }
    .dist-stats__source {
      font-size: var(--fs-label);
      color: rgba(255, 255, 255, 0.55);
      letter-spacing: 0.04em;
    }
    @media (max-width: 900px) {
      .dist-stats__grid { grid-template-columns: 1fr; gap: var(--space-4); }
    }

    /* ---------- INTRO ---------- */
    .dist-intro {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-7);
      align-items: start;
    }
    .dist-intro__copy h2 {
      font-size: clamp(1.875rem, 2vw + 1rem, 2.5rem);
      line-height: 1.15;
      letter-spacing: -0.015em;
      margin: var(--space-3) 0 var(--space-5);
    }
    .dist-intro__copy p {
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--bbg-text);
      margin-bottom: var(--space-4);
    }
    .dist-intro__copy p:last-child { margin-bottom: 0; }
    .dist-intro__pull {
      position: relative;
      padding: var(--space-6);
      background: var(--bbg-blue-light);
      border-radius: var(--radius-lg);
      border-left: 4px solid var(--bbg-blue);
    }
    .dist-intro__pull p {
      margin: 0;
      font-size: 1.25rem;
      line-height: 1.45;
      color: var(--bbg-ink);
      font-weight: 500;
      letter-spacing: -0.005em;
    }
    .dist-intro__quote-mark {
      position: absolute;
      top: -10px;
      left: var(--space-4);
      font-size: 4rem;
      line-height: 1;
      color: var(--bbg-blue);
      font-weight: 700;
      font-family: Georgia, serif;
    }
    @media (max-width: 900px) {
      .dist-intro { grid-template-columns: 1fr; gap: var(--space-5); }
    }

    /* ---------- FILTERS (4 cards) ---------- */
    .dist-filters {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-5);
    }
    .dist-filter {
      position: relative;
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
    }
    .dist-filter:hover {
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
      transform: translateY(-3px);
    }
    .dist-filter__n {
      display: inline-block;
      font-size: 2rem;
      font-weight: 700;
      color: var(--bbg-blue);
      line-height: 1;
      letter-spacing: -0.02em;
      margin-bottom: var(--space-4);
      font-feature-settings: "tnum";
    }
    .dist-filter__title {
      font-size: 1.375rem;
      line-height: 1.25;
      margin: 0 0 var(--space-3);
      letter-spacing: -0.01em;
    }
    .dist-filter__body {
      font-size: 1rem;
      line-height: 1.65;
      color: var(--bbg-text);
      margin: 0;
    }
    @media (max-width: 900px) {
      .dist-filters { grid-template-columns: 1fr; }
    }

    /* ---------- CHANNELS (offline + online) ---------- */
    .dist-channels {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }
    .dist-channels__column {
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }
    .dist-channels__head { border-bottom: 1px solid var(--bbg-border); padding-bottom: var(--space-4); }
    .dist-channels__head h3 {
      font-size: 1.5rem;
      margin: var(--space-3) 0 var(--space-3);
      letter-spacing: -0.01em;
    }
    .dist-channels__head p {
      margin: 0;
      color: var(--bbg-text);
      line-height: 1.55;
      font-size: 0.9375rem;
    }
    .dist-channels__tag {
      display: inline-block;
      font-size: var(--fs-label);
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.35em 0.85em;
      border-radius: 999px;
    }
    .dist-channels__tag--offline { background: var(--bbg-ink); color: var(--bbg-white); }
    .dist-channels__tag--online { background: var(--bbg-blue); color: var(--bbg-white); }

    .dist-chains {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .dist-chain {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      padding: var(--space-3) var(--space-4);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-md);
      background: var(--bbg-surface);
      transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
    }
    .dist-chain:hover {
      border-color: var(--bbg-blue);
      background: var(--bbg-white);
    }
    .dist-chain__cn {
      font-family: "PingFang SC", "Microsoft YaHei", -apple-system, BlinkMacSystemFont, sans-serif;
      font-size: 1.625rem;
      font-weight: 600;
      color: var(--bbg-ink);
      line-height: 1;
      letter-spacing: 0.02em;
      flex-shrink: 0;
      min-width: 5.5rem;
    }
    .dist-chain__meta { display: flex; flex-direction: column; gap: 2px; }
    .dist-chain__en {
      font-size: 1rem;
      font-weight: 600;
      color: var(--bbg-ink);
      letter-spacing: -0.005em;
    }
    .dist-chain__sub {
      font-size: 0.8125rem;
      color: var(--bbg-text-muted);
      line-height: 1.35;
    }

    .dist-platforms {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
    }
    .dist-platform {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: var(--space-4) var(--space-3);
      background: var(--bbg-surface);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-md);
      text-align: center;
      transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease), transform var(--dur) var(--ease);
    }
    .dist-platform:hover {
      border-color: var(--bbg-blue);
      background: var(--bbg-white);
      transform: translateY(-2px);
    }
    .dist-platform__logo {
      width: 44px;
      height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--bbg-white);
      border-radius: var(--radius-sm);
      padding: 6px;
    }
    .dist-platform__logo img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }
    .dist-platform__en {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--bbg-ink);
      margin-top: 2px;
    }
    .dist-platform__cn {
      font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
      font-size: 0.8125rem;
      color: var(--bbg-text-muted);
    }
    @media (max-width: 1024px) {
      .dist-channels { grid-template-columns: 1fr; }
    }
    @media (max-width: 560px) {
      .dist-platforms { grid-template-columns: repeat(2, 1fr); }
    }

    /* ---------- SETUPS (who runs marketing) ---------- */
    .dist-setups {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
      align-items: stretch;
    }
    .dist-setup {
      position: relative;
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    }
    .dist-setup:hover {
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
    }
    .dist-setup--highlight {
      background: linear-gradient(180deg, var(--bbg-blue-light) 0%, var(--bbg-white) 50%);
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
    }
    .dist-setup__badge {
      position: absolute;
      top: -12px;
      left: var(--space-6);
      background: var(--bbg-blue);
      color: var(--bbg-white);
      font-size: var(--fs-label);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.4em 0.9em;
      border-radius: 999px;
    }
    .dist-setup__tag {
      font-size: var(--fs-label);
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--bbg-blue);
    }
    .dist-setup__title {
      font-size: 1.375rem;
      line-height: 1.25;
      margin: 0;
      letter-spacing: -0.01em;
    }
    .dist-setup__body {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--bbg-text);
      margin: 0;
      flex-grow: 1;
    }
    .dist-setup__cost {
      background: var(--bbg-surface);
      border-radius: var(--radius-md);
      padding: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: 4px;
      border-top: 3px solid var(--bbg-blue);
    }
    .dist-setup--highlight .dist-setup__cost { background: var(--bbg-white); }
    .dist-setup__cost-label {
      font-size: var(--fs-label);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--bbg-text-muted);
    }
    .dist-setup__cost-value {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--bbg-ink);
      letter-spacing: -0.01em;
      font-feature-settings: "tnum";
    }
    .dist-setup__cost-note {
      font-size: 0.8125rem;
      line-height: 1.5;
      color: var(--bbg-text);
      margin: 4px 0 0;
    }
    @media (max-width: 1024px) {
      .dist-setups { grid-template-columns: 1fr; }
    }

    /* ---------- SERVICES (5 cards) ---------- */
    .dist-services {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: var(--space-4);
    }
    .dist-service {
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease);
    }
    .dist-service:hover {
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
      transform: translateY(-3px);
    }
    .dist-service__icon {
      display: inline-flex;
      width: 44px;
      height: 44px;
      align-items: center;
      justify-content: center;
      border-radius: var(--radius-md);
      background: var(--bbg-blue-light);
      color: var(--bbg-blue);
      margin-bottom: var(--space-4);
    }
    .dist-service__icon svg { width: 22px; height: 22px; }
    .dist-service__title {
      font-size: 1.0625rem;
      line-height: 1.25;
      margin: 0 0 var(--space-3);
      letter-spacing: -0.005em;
    }
    .dist-service__desc {
      font-size: 0.875rem;
      line-height: 1.55;
      color: var(--bbg-text);
      margin: 0;
    }
    @media (max-width: 1024px) {
      .dist-services { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .dist-services { grid-template-columns: 1fr; }
    }

    /* ---------- MODELS ---------- */
    .dist-models {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-5);
      align-items: stretch;
    }
    .dist-model {
      position: relative;
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-7);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    }
    .dist-model:hover {
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
    }
    .dist-model--highlight {
      background: linear-gradient(180deg, var(--bbg-blue-light) 0%, var(--bbg-white) 60%);
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
    }
    .dist-model__badge {
      position: absolute;
      top: -12px;
      left: var(--space-7);
      background: var(--bbg-blue);
      color: var(--bbg-white);
      font-size: var(--fs-label);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.4em 0.9em;
      border-radius: 999px;
    }
    .dist-model__title {
      font-size: 1.5rem;
      line-height: 1.2;
      margin: 0;
      letter-spacing: -0.01em;
    }
    .dist-model__desc {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--bbg-text);
      margin: 0;
    }
    .dist-model__list {
      list-style: none;
      padding: var(--space-4) 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      border-top: 1px solid var(--bbg-border);
      border-bottom: 1px solid var(--bbg-border);
    }
    .dist-model__list li {
      position: relative;
      padding-left: 1.5rem;
      font-size: 0.95rem;
      line-height: 1.5;
      color: var(--bbg-text);
    }
    .dist-model__list li::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.55em;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--bbg-blue);
    }
    .dist-model__pricing { display: flex; flex-direction: column; gap: 0.25rem; }
    .dist-model__pricing-label {
      font-size: var(--fs-label);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--bbg-text-muted);
    }
    .dist-model__pricing-value {
      font-size: 1rem;
      color: var(--bbg-ink);
      font-weight: 600;
      line-height: 1.4;
    }
    .dist-model__cta { align-self: flex-start; margin-top: auto; }
    @media (max-width: 1024px) {
      .dist-models { grid-template-columns: 1fr; }
      .dist-model { padding: var(--space-6); }
    }

    /* ---------- STEPS / TIMELINE ---------- */
    .dist-steps {
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 880px;
    }
    .dist-step {
      position: relative;
      display: grid;
      grid-template-columns: 36px 1fr;
      gap: var(--space-5);
      padding-bottom: var(--space-6);
    }
    .dist-step:last-child { padding-bottom: 0; }
    .dist-step__rail {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .dist-step__dot {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--bbg-blue);
      border: 4px solid var(--bbg-white);
      box-shadow: 0 0 0 2px var(--bbg-blue);
      margin-top: 6px;
      flex-shrink: 0;
    }
    .dist-step__line {
      flex-grow: 1;
      width: 2px;
      background: linear-gradient(to bottom, var(--bbg-blue) 0%, var(--bbg-border) 100%);
      margin-top: 4px;
    }
    .dist-step__body {
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      padding: var(--space-5);
      transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
    }
    .dist-step__body:hover {
      border-color: var(--bbg-blue);
      box-shadow: var(--shadow-md);
    }
    .dist-step__head {
      display: flex;
      align-items: baseline;
      gap: var(--space-3);
      flex-wrap: wrap;
      margin-bottom: var(--space-2);
    }
    .dist-step__n {
      font-size: 1.125rem;
      font-weight: 700;
      color: var(--bbg-blue);
      letter-spacing: -0.01em;
      font-feature-settings: "tnum";
    }
    .dist-step__title {
      font-size: 1.25rem;
      line-height: 1.25;
      margin: 0;
      letter-spacing: -0.01em;
    }
    .dist-step__time {
      margin-left: auto;
      font-size: var(--fs-label);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--bbg-text-muted);
      background: var(--bbg-surface);
      padding: 0.3em 0.7em;
      border-radius: 999px;
    }
    .dist-step__desc {
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--bbg-text);
      margin: 0;
    }
    @media (max-width: 560px) {
      .dist-step { grid-template-columns: 24px 1fr; gap: var(--space-3); }
      .dist-step__dot { width: 12px; height: 12px; border-width: 3px; }
      .dist-step__head { gap: var(--space-2); }
      .dist-step__time { margin-left: 0; }
    }

    /* ---------- FAQ ---------- */
    .dist-faq {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .dist-faq__item {
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-md);
      overflow: hidden;
      transition: border-color var(--dur) var(--ease);
    }
    .dist-faq__item[open] { border-color: var(--bbg-blue); }
    .dist-faq__q {
      cursor: pointer;
      padding: var(--space-5);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      font-weight: 600;
      font-size: 1.0625rem;
      line-height: 1.3;
      color: var(--bbg-ink);
      list-style: none;
      transition: color var(--dur) var(--ease);
    }
    .dist-faq__q::-webkit-details-marker { display: none; }
    .dist-faq__q::marker { display: none; }
    .dist-faq__item:hover .dist-faq__q { color: var(--bbg-blue); }
    .dist-faq__icon {
      flex-shrink: 0;
      width: 24px;
      height: 24px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--bbg-text-muted);
      transition: transform var(--dur) var(--ease), color var(--dur) var(--ease);
    }
    .dist-faq__item[open] .dist-faq__icon {
      transform: rotate(180deg);
      color: var(--bbg-blue);
    }
    .dist-faq__a {
      padding: 0 var(--space-5) var(--space-5);
      color: var(--bbg-text);
      line-height: 1.65;
      font-size: 1rem;
    }
    .dist-faq__a p { margin: 0; }

    /* ---------- FINAL CTA ---------- */
    .dist-cta {
      padding: clamp(var(--space-6), 4vw + 1rem, var(--space-8)) var(--space-6);
      background: linear-gradient(135deg, var(--bbg-blue) 0%, var(--bbg-blue-dark) 100%);
      color: var(--bbg-white);
      border-radius: var(--radius-lg);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .dist-cta::before {
      content: "";
      position: absolute;
      top: -40%;
      right: -10%;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle at center, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0) 65%);
      pointer-events: none;
    }
    .dist-cta .eyebrow--on-dark {
      display: inline-block;
      margin-bottom: var(--space-4);
      color: rgba(255, 255, 255, 0.9);
    }
    .dist-cta__title {
      font-size: clamp(1.75rem, 1.5vw + 1rem, 2.5rem);
      line-height: 1.15;
      color: var(--bbg-white);
      margin: 0 0 var(--space-4);
