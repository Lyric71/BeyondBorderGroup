---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('cases', ({ data }) => !data.draft);
  return all.map((c) => ({
    params: { slug: c.id },
    props: { entry: c },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const allCases = await getCollection('cases', ({ data }) => !data.draft);
const related = allCases
  .filter((c) => c.id !== entry.id && c.data.category === d.category)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Layout
  title={`${d.brand}: ${d.title} | Beyond Border Group`}
  description={d.summary}
>
  <article class="case">
    {/* ---------- HERO ---------- */}
    <section class="case-hero">
      <div class="case-hero__bg" aria-hidden="true">
        <img src={d.heroImage} alt="" />
      </div>
      <div class="case-hero__overlay" aria-hidden="true"></div>

      <div class="container case-hero__inner">
        <nav class="case-hero__crumbs" aria-label="Breadcrumb">
          <a href="/work">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
            All case studies
          </a>
        </nav>
        <span class="eyebrow eyebrow--on-dark">{d.category}</span>
        <h1 class="case-hero__title">{d.brand}</h1>
        <p class="case-hero__tagline">{d.title}</p>
      </div>
    </section>

    {/* ---------- META CARD (overlaps hero/body boundary) ---------- */}
    <section class="case-meta-wrap">
      <div class="container">
        <div class="case-meta">
          <div class="case-meta__cell">
            <span class="eyebrow">Category</span>
            <p class="case-meta__value">{d.category}</p>
          </div>
          <div class="case-meta__cell case-meta__cell--services">
            <span class="eyebrow">Services delivered</span>
            <ul class="case-meta__services">
              {d.services.map((s) => <li>{s}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ---------- SUMMARY / PULL QUOTE ---------- */}
    <section class="case-intro">
      <div class="container container--narrow">
        <p class="case-intro__summary">{d.summary}</p>
      </div>
    </section>

    {/* ---------- BODY ---------- */}
    <div class="case-body">
      <div class="container container--narrow">
        <div class="prose prose--case">
          <Content />
        </div>
      </div>
    </div>

    {/* ---------- GALLERY ---------- */}
    {d.images.length > 0 && (
      <section class="case-gallery">
        <div class="container">
          <header class="case-gallery__head">
            <span class="eyebrow">Project visuals</span>
            <h2 class="case-gallery__title">Inside the work</h2>
          </header>
          <div class="case-gallery__stack">
            {d.images.map((img) => (
              <figure class="case-gallery__figure">
                <div class="case-gallery__image">
                  <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
                </div>
                {img.caption && <figcaption>{img.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ---------- CTA ---------- */}
    <section class="case-cta-wrap">
      <div class="container container--narrow">
        <div class="case-cta">
          <span class="eyebrow eyebrow--on-dark">Let's talk</span>
          <h2 class="case-cta__title">Thinking about your own China story?</h2>
          <p class="case-cta__lead">
            Tell us where you are today and where you'd like to be. Real humans on our side, no sales funnel, no forms that never get read.
          </p>
          <div class="case-cta__actions">
            <a href="/contact" class="btn case-cta__btn-primary">Start the conversation</a>
            <a href="/work" class="btn case-cta__btn-ghost">More case studies</a>
          </div>
        </div>
      </div>
    </section>

    {/* ---------- RELATED ---------- */}
    {related.length > 0 && (
      <section class="section section--alt">
        <div class="container">
          <header class="section-header section-header--split">
            <div>
              <span class="eyebrow">Related work</span>
              <h2>More in {d.category}</h2>
            </div>
            <a href="/work" class="btn btn--secondary btn--sm">All case studies</a>
          </header>

          <div class="grid grid-3">
            {related.map((c) => (
              <a href={`/work/${c.id}`} class="work-card">
                <div class="work-card__image">
                  <img src={c.data.heroImage} alt={c.data.heroImageAlt || `${c.data.brand} case study`} loading="lazy" decoding="async" width="600" height="400" />
                </div>
                <div class="work-card__body">
                  <span class="work-card__tag">{c.data.category}</span>
                  <h3 class="work-card__title">{c.data.brand}</h3>
                  <p class="work-card__summary">{c.data.title}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>

  <style is:global>
    /* ---------- CONTAINER MODIFIER ---------- */
    .container--narrow {
      max-width: 760px;
      margin-inline: auto;
      padding-inline: var(--container-pad);
    }

    /* ---------- HERO ---------- */
    .case-hero {
      position: relative;
      min-height: 68vh;
      min-height: clamp(520px, 68vh, 760px);
      display: flex;
      align-items: flex-end;
      padding: var(--space-8) 0 var(--space-7);
      color: var(--bbg-white);
      overflow: hidden;
      isolation: isolate;
    }
    .case-hero__bg {
      position: absolute;
      inset: 0;
      z-index: -2;
    }
    .case-hero__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }
    .case-hero__overlay {
      position: absolute;
      inset: 0;
      z-index: -1;
      background:
        linear-gradient(180deg,
          rgba(10, 20, 28, 0.35) 0%,
          rgba(10, 20, 28, 0.45) 40%,
          rgba(10, 20, 28, 0.80) 80%,
          rgba(10, 20, 28, 0.92) 100%);
    }
    .case-hero__inner {
      max-width: 880px;
      position: relative;
    }
    .case-hero__crumbs {
      margin-bottom: var(--space-5);
      font-size: var(--fs-small);
    }
    .case-hero__crumbs a {
      color: rgba(255, 255, 255, 0.8);
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: color var(--dur) var(--ease);
    }
    .case-hero__crumbs a:hover { color: var(--bbg-white); }
    .case-hero__inner .eyebrow--on-dark {
      display: inline-block;
      margin-bottom: var(--space-4);
      color: #9DDBF5;
    }
    .case-hero__title {
      font-size: clamp(2.75rem, 5vw + 1rem, 4.75rem);
      line-height: 1.02;
      letter-spacing: -0.02em;
      color: var(--bbg-white);
      margin: 0 0 var(--space-4);
      text-wrap: balance;
    }
    .case-hero__tagline {
      font-size: clamp(1.125rem, 1vw + 0.875rem, 1.5rem);
      line-height: 1.35;
      color: rgba(255, 255, 255, 0.92);
      max-width: 56ch;
      margin: 0;
      font-weight: 400;
      text-wrap: pretty;
    }

    /* ---------- META CARD ---------- */
    .case-meta-wrap {
      position: relative;
      z-index: 2;
      margin-top: calc(var(--space-7) * -1);
      padding-bottom: var(--space-6);
    }
    .case-meta {
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      padding: var(--space-6);
      display: grid;
      grid-template-columns: minmax(180px, 1fr) minmax(0, 3fr);
      gap: var(--space-6);
      align-items: start;
    }
    .case-meta__cell {
      min-width: 0;
    }
    .case-meta__cell .eyebrow {
      display: block;
      margin-bottom: var(--space-3);
    }
    .case-meta__value {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--bbg-ink);
      line-height: 1.25;
      margin: 0;
    }
    .case-meta__services {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 0.5rem;
    }
    .case-meta__services li {
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--bbg-text);
      background: var(--bbg-surface);
      border: 1px solid var(--bbg-border);
      padding: 0.35em 0.85em;
      border-radius: 999px;
      white-space: nowrap;
    }

    /* ---------- INTRO / SUMMARY PULL QUOTE ---------- */
    .case-intro {
      padding: var(--space-7) 0 var(--space-5);
    }
    .case-intro__summary {
      font-size: clamp(1.375rem, 1.2vw + 0.875rem, 1.75rem);
      line-height: 1.4;
      color: var(--bbg-ink);
      font-weight: 500;
      letter-spacing: -0.01em;
      margin: 0;
      padding-left: var(--space-5);
      border-left: 3px solid var(--bbg-blue);
      text-wrap: pretty;
    }

    /* ---------- BODY ---------- */
    .case-body {
      padding: var(--space-4) 0 var(--space-8);
    }

    .prose--case {
      font-size: 1.15rem;
      line-height: 1.75;
      color: var(--bbg-text);
    }
    .prose--case > * + * { margin-top: 1.25em; }
    .prose--case h2 {
      font-size: clamp(1.625rem, 1.5vw + 0.875rem, 2.125rem);
      line-height: 1.2;
      color: var(--bbg-ink);
      letter-spacing: -0.01em;
      margin-top: 2.4em;
      margin-bottom: 0.7em;
      position: relative;
      padding-left: 1.4rem;
      font-weight: 700;
    }
    .prose--case h2::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.38em;
      bottom: 0.38em;
      width: 4px;
      border-radius: 2px;
      background: var(--bbg-blue);
    }
    .prose--case h2:first-child { margin-top: 0; }
    .prose--case h3 {
      font-size: 1.375rem;
      line-height: 1.3;
      color: var(--bbg-ink);
      margin-top: 1.8em;
      margin-bottom: 0.5em;
      font-weight: 600;
    }
    .prose--case p { margin: 0 0 1.25em; }
    .prose--case p:last-child { margin-bottom: 0; }
    .prose--case a {
      color: var(--bbg-blue);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .prose--case a:hover { color: var(--bbg-blue-dark); }
    .prose--case strong { color: var(--bbg-ink); font-weight: 700; }
    .prose--case ul, .prose--case ol {
      padding-left: 1.5rem;
      margin: 0 0 1.25em;
    }
    .prose--case li {
      margin-bottom: 0.55em;
      padding-left: 0.25rem;
    }
    .prose--case ul li::marker { color: var(--bbg-blue); font-size: 1.1em; }
    .prose--case blockquote {
      margin: 2em 0;
      padding: 0.4em 0 0.4em 1.5em;
      border-left: 3px solid var(--bbg-blue);
      font-style: italic;
      font-size: 1.25rem;
      line-height: 1.5;
      color: var(--bbg-ink);
    }
    .prose--case img {
      width: 100%;
      border-radius: var(--radius-md);
      margin: 2em 0;
    }
    .prose--case hr {
      border: 0;
      border-top: 1px solid var(--bbg-border);
      margin: 2.5em 0;
    }

    /* ---------- GALLERY ---------- */
    .case-gallery {
      padding: var(--space-8) 0;
      background: var(--bbg-surface);
      border-top: 1px solid var(--bbg-border);
      border-bottom: 1px solid var(--bbg-border);
    }
    .case-gallery__head {
      text-align: center;
      margin-bottom: var(--space-6);
    }
    .case-gallery__head .eyebrow {
      display: inline-block;
      margin-bottom: var(--space-3);
    }
    .case-gallery__title {
      font-size: clamp(1.75rem, 2vw + 1rem, 2.5rem);
      margin: 0;
      letter-spacing: -0.01em;
    }
    .case-gallery__stack {
      display: flex;
      flex-direction: column;
      gap: var(--space-6);
      max-width: 960px;
      margin-inline: auto;
    }
    .case-gallery__figure {
      margin: 0;
      background: var(--bbg-white);
      border: 1px solid var(--bbg-border);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .case-gallery__image {
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bbg-surface);
      padding: var(--space-3);
    }
    .case-gallery__image img {
      max-width: 100%;
      max-height: 720px;
      width: auto;
      height: auto;
      display: block;
      border-radius: var(--radius-sm);
    }
    .case-gallery__figure figcaption {
      padding: var(--space-4) var(--space-5);
      font-size: var(--fs-small);
      color: var(--bbg-text-muted);
      border-top: 1px solid var(--bbg-border);
      text-align: center;
    }

    /* ---------- CTA ---------- */
    .case-cta-wrap {
      padding: var(--space-8) 0 var(--space-7);
    }
    .case-cta {
      padding: clamp(var(--space-6), 4vw + 1rem, var(--space-8)) var(--space-6);
      background: linear-gradient(135deg, var(--bbg-blue) 0%, var(--bbg-blue-dark) 100%);
      color: var(--bbg-white);
      border-radius: var(--radius-lg);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .case-cta::before {
      content: "";
      position: absolute;
      top: -40%;
      right: -10%;
      width: 420px;
      height: 420px;
      background: radial-gradient(circle at center, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0) 65%);
      pointer-events: none;
    }
    .case-cta .eyebrow--on-dark {
      display: inline-block;
      margin-bottom: var(--space-4);
      color: rgba(255, 255, 255, 0.85);
    }
    .case-cta__title {
      font-size: clamp(1.625rem, 1.5vw + 1rem, 2.25rem);
      line-height: 1.2;
      color: var(--bbg-white);
      margin: 0 0 var(--space-4);
      letter-spacing: -0.01em;
    }
    .case-cta__lead {
      color: rgba(255, 255, 255, 0.92);
      font-size: 1.0625rem;
      max-width: 52ch;
      margin: 0 auto var(--space-5);
      line-height: 1.55;
    }
    .case-cta__actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
      justify-content: center;
      position: relative;
    }
    .case-cta__btn-primary {
      background: var(--bbg-white);
      color: var(--bbg-blue-dark);
      border: 1px solid var(--bbg-white);
    }
    .case-cta__btn-primary:hover {
      background: rgba(255, 255, 255, 0.92);
      color: var(--bbg-blue-dark);
    }
    .case-cta__btn-ghost {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.5);
      color: var(--bbg-white);
    }
    .case-cta__btn-ghost:hover {
      background: rgba(255, 255, 255, 0.12);
      border-color: var(--bbg-white);
      color: var(--bbg-white);
    }

    /* ---------- RESPONSIVE ---------- */
    @media (max-width: 900px) {
      .case-hero {
        min-height: clamp(440px, 60vh, 600px);
        padding: var(--space-7) 0 var(--space-6);
      }
      .case-meta {
        grid-template-columns: 1fr;
        gap: var(--space-4);
        padding: var(--space-5);
      }
      .case-meta-wrap { margin-top: calc(var(--space-6) * -1); }
      .case-gallery__image { padding: var(--space-2); }
      .case-gallery__image img { max-height: 520px; }
    }
    @media (max-width: 640px) {
      .case-intro__summary {
        padding-left: var(--space-4);
        font-size: 1.25rem;
      }
      .prose--case { font-size: 1.0625rem; line-height: 1.7; }
      .prose--case h2 { padding-left: 1rem; }
      .prose--case h2::before { width: 3px; }
    }
  </style>
</Layout>
