---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Cyril Drouin',
    role: 'Founder & CEO',
    base: 'Shanghai / Paris',
    photo: '/Images/team/cyril-drouin.jpg',
    bio: '25 years in digital, advertising and commerce. Former CEO of Publicis Commerce and Performance Marketing for China and North Asia. Builds the strategy and runs the operations.',
    linkedin: 'https://www.linkedin.com/in/cyril-d-68835729/',
    twitter: 'https://twitter.com/CyrilDrouin',
    substack: 'https://cyrildrouin.substack.com',
  },
  {
    name: 'Echo Peng',
    role: 'Senior Director & Partner',
    base: 'Shanghai',
    photo: '/Images/team/echo-peng.jpg',
    bio: '18 years running eCommerce and digital for global brands in China. Former operations director at Publicis China. Owns the platforms, the stores, the day-to-day.',
    linkedin: 'https://www.linkedin.com/in/echo-peng/',
  },
  {
    name: 'Liyan Ye',
    role: 'Senior Director',
    base: 'Shanghai',
    photo: '/Images/team/liyan-ye.jpg',
    bio: '20 years of marketing experience with Fortune 500 brands in China. Leads brand building, campaigns and the work that turns platform activity into a brand.',
    linkedin: 'https://www.linkedin.com/in/liyan-ye/',
  },
];

const credentials = [
  {
    title: 'Former 4A agency directors',
    body: 'We built brand growth strategies across China and North Asia for global portfolios. Market entry, platform ecosystems, partnership frameworks. The things clients pay 4A agencies to figure out, we were the ones figuring out.',
    image: '/Images/about/credentials/01-4a-directors.png',
  },
  {
    title: 'Platform strategists',
    body: 'Commerce and content strategies for Tmall, JD, Douyin and Xiaohongshu. We know how platform dynamics actually shape brand outcomes, not the version in a pitch deck.',
    image: '/Images/about/credentials/02-platform-strategists.png',
  },
  {
    title: 'Brand growth architects',
    body: 'We have designed China market approaches for dozens of international brands. Through regulatory shifts, competitive reshuffles, and a decade of consumer evolution.',
    image: '/Images/about/credentials/03-brand-architects.png',
  },
  {
    title: 'No strategy-execution gap',
    body: 'Senior strategists who also run operations. The person writing your China growth roadmap is the same person making sure it actually works. No lost translation between planning and performance.',
    image: '/Images/about/credentials/04-no-gap.png',
  },
  {
    title: 'Proven across categories',
    body: 'We have launched beauty brands on Xiaohongshu. Reversed F&B sales declines on Tmall. Built automotive consideration through Douyin. The people who understand China strategy are the same people running your campaigns.',
    image: '/Images/about/credentials/05-categories.png',
  },
];

const principles = [
  {
    title: "We don't outsource your success",
    body: 'The strategist who plans your China entry is the same person optimising your Douyin ads at 2am Beijing time. No handoffs to junior teams. No "advisors" who have not logged into a Chinese platform in years.',
    icon: 'hands',
  },
  {
    title: 'We only take projects we can win',
    body: "We turn down work that does not fit our expertise. Your results matter more than our client count. If we cannot move the needle for your brand in China, we will tell you upfront.",
    icon: 'target',
  },
  {
    title: 'We think cross-border, not export',
    body: "China is not your home market with Chinese characters. We build strategies that work inside China's ecosystem, from payment rails to platform algorithms to consumer behaviour that does not exist anywhere else.",
    icon: 'globe',
  },
  {
    title: 'We know the mechanics, not just the theory',
    body: "Ask us about Tmall's search ranking factors. Xiaohongshu's content moderation triggers. WeChat's conversion tracking limits. We have broken these platforms, fixed them, and scaled campaigns through them for 15+ years.",
    icon: 'gears',
  },
  {
    title: 'We have built the relationships that matter',
    body: "25 years in China means we know who to call when platforms change their rules overnight. Distributors who actually answer their phones. TP partners who will not ghost you after onboarding. KOL agencies that vet their influencers. These relationships are not in a CRM, they are built on years of solving problems together.",
    icon: 'network',
  },
  {
    title: 'We have sat in your chair',
    body: "Before Beyond Border, we ran commerce teams at Publicis. Managed P&Ls for brand flagship stores. Negotiated platform penalties at 3am. We know what keeps you up at night because we have lived it.",
    icon: 'chair',
  },
];

const principleIcon: Record<string, string> = {
  hands:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11V5a1.5 1.5 0 0 1 3 0v5"/><path d="M12 10V4a1.5 1.5 0 0 1 3 0v7"/><path d="M15 11V6a1.5 1.5 0 0 1 3 0v9"/><path d="M18 11V8a1.5 1.5 0 0 1 3 0v7a6 6 0 0 1-6 6H9a5 5 0 0 1-4.5-2.8L2 13.5a1.5 1.5 0 0 1 2.6-1.4L6 14"/></svg>',
  target:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5.5"/><circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/></svg>',
  globe:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a13 13 0 0 1 0 18"/><path d="M12 3a13 13 0 0 0 0 18"/></svg>',
  gears:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="9.5" cy="9.5" r="3"/><path d="M9.5 2v2M9.5 15v2M2 9.5h2M15 9.5h2M4.2 4.2l1.4 1.4M13.4 13.4l1.4 1.4M4.2 14.8l1.4-1.4M13.4 5.6l1.4-1.4"/><circle cx="17" cy="17" r="2.2"/><path d="M17 12v1.5M17 20.5V22M12 17h1.5M20.5 17H22"/></svg>',
  network: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2.5"/><circle cx="19" cy="6" r="2.5"/><circle cx="12" cy="18" r="2.5"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="M7 7l4 10M17 7l-4 10M7.5 6h9M6 8v8M18 8v8"/></svg>',
  chair:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3v8h14V3"/><path d="M3 11h18"/><path d="M5 11v6a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3v-6"/><path d="M7 20l-1 2M17 20l1 2"/></svg>',
};

const metrics = [
  { target: 15,  suffix: '+', label: 'Years building brands in China' },
  { target: 60,  suffix: '+', label: 'Brands grown across eCommerce, media and distribution' },
  { target: 100, suffix: '+', label: 'Campaigns delivered on Chinese platforms' },
  { target: 50,  suffix: '+', label: 'Consulting engagements for global brands' },
];

const clients = [
  { name: 'Shiseido',     logo: '/Images/clients/shiseido.png' },
  { name: 'Pierre Fabre', logo: '/Images/clients/pierre-fabre.png' },
  { name: 'iFlytek',      logo: '/Images/clients/iflytek.png' },
  { name: 'Camper',       logo: '/Images/clients/camper.png' },
  { name: 'Into You',     logo: '/Images/clients/into-you.png' },
];
---

<Layout
  title="Who We Are | Beyond Border Group"
  description="Former Publicis executives who spent 15 years growing global brands in China. Strategy and execution under one roof, with the same senior people on both."
>

  {/* ---------- HERO ---------- */}
  <section class="hero about-hero">
    <div class="about-hero__bg" aria-hidden="true">
      <img
        src="/Images/team/china-office.png"
        alt=""
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </div>
    <div class="about-hero__overlay" aria-hidden="true"></div>

    <div class="container about-hero__inner">
      <span class="eyebrow eyebrow--on-dark">Who we are</span>
      <h1 class="hero__title">We run your China growth. We don't just advise on it.</h1>
      <p class="hero__lead">
        15 years building brands in China for Publicis. Now doing it for yours.
        Strategy without execution is just expensive PowerPoint.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/contact">Talk to us</a>
        <a class="btn btn--ghost-light" href="#leadership">Meet the team</a>
      </div>
    </div>
  </section>

  {/* ---------- WHY WE EXIST ---------- */}
  <section class="section section--alt">
    <div class="container">
      <div class="about-split">
        <div class="about-split__copy">
          <span class="eyebrow">Why we exist</span>
          <h2>Experience you can't Google.</h2>
          <p class="lead">
            Beyond Border Group was founded by former Publicis executives who spent 15 years
            growing global brands across China. Inside Tmall dashboards, Douyin studios,
            distributor negotiations. Not boardrooms.
          </p>
          <p>
            The pattern we saw over and over: brands got brilliant China strategies, then
            watched junior teams fumble the execution. Beautiful decks, mediocre results.
          </p>
          <p>
            So we built something different. We write the plan and we run it. Same senior
            people, from the first workshop to the monthly P&L review. No hand-off, no
            translation loss, no one else to blame when things get hard.
          </p>
        </div>

        <aside class="about-signature" aria-label="Signature of Cyril Drouin, Founder">
          <figure>
            <img
              src="/Images/team/Cyril-Drouin-Signature-Transparent.png"
              alt="Signature of Cyril Drouin, Founder of Beyond Border Group"
              loading="lazy"
              decoding="async"
              width="512"
              height="280"
            />
            <figcaption>
              <strong>Cyril Drouin</strong>
              <span>Founder &amp; CEO, Beyond Border Group</span>
            </figcaption>
          </figure>
        </aside>
      </div>
    </div>
  </section>

  {/* ---------- LEADERSHIP ---------- */}
  <section id="leadership" class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Our leadership</span>
        <h2>We learned China marketing by launching brands there, not by reading about it.</h2>
        <p class="lead">
          Former 4A agency directors. Tmall, JD, Douyin and RED specialists.
          Brand builders and P&L owners. One team, one phone number.
        </p>
      </header>

      <div class="grid grid-3 team-grid">
        {team.map((t) => (
          <article class="team-card">
            <div class="team-card__photo">
              <img
                src={t.photo}
                alt={`${t.name}, ${t.role}`}
                loading="lazy"
                decoding="async"
                width="480"
                height="480"
              />
            </div>
            <div class="team-card__body">
              <h3 class="team-card__name">{t.name}</h3>
              <span class="team-card__role">{t.role}</span>
              <span class="team-card__base">{t.base}</span>
              <p>{t.bio}</p>

              <ul class="team-card__links" aria-label={`${t.name} profiles`}>
                {t.linkedin && (
                  <li>
                    <a href={t.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${t.name} on LinkedIn`}>
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19 3A2 2 0 0 1 21 5v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.34V9.82H5.67v8.52h2.67zm-1.33-9.7a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zM18.34 18.34v-4.66c0-2.5-1.34-3.66-3.12-3.66a2.7 2.7 0 0 0-2.44 1.34h-.04V9.82h-2.56v8.52h2.67v-4.22c0-1.11.21-2.18 1.59-2.18s1.38 1.27 1.38 2.25v4.15h2.52z"/>
                      </svg>
                    </a>
                  </li>
                )}
                {t.twitter && (
                  <li>
                    <a href={t.twitter} target="_blank" rel="noopener noreferrer" aria-label={`${t.name} on X / Twitter`}>
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </a>
                  </li>
                )}
                {t.substack && (
                  <li>
                    <a href={t.substack} target="_blank" rel="noopener noreferrer" aria-label={`${t.name} on Substack`}>
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/>
                      </svg>
                    </a>
                  </li>
                )}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- STRATEGIC LEADERSHIP WITH OPERATIONAL DEPTH ---------- */}
  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Strategic leadership, operational depth</span>
        <h2>15 years of China marketing, digital and eCommerce. Each team member.</h2>
      </header>

      <div class="grid grid-3 credentials">
        {credentials.map((c) => (
          <figure class="credential">
            <div class="credential__bg" aria-hidden="true">
              <img src={c.image} alt="" loading="lazy" decoding="async" />
            </div>
            <div class="credential__overlay" aria-hidden="true"></div>
            <figcaption class="credential__inner">
              <h3 class="credential__title">{c.title}</h3>
              <p>{c.body}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- WHAT MAKES US DIFFERENT ---------- */}
  <section class="section">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">What makes us different</span>
        <h2>Six things we will not change.</h2>
      </header>

      <div class="grid grid-3 principles">
        {principles.map((p, i) => (
          <article class="card principle">
            <div class="principle__head">
              <span class="principle__icon" aria-hidden="true" set:html={principleIcon[p.icon]} />
              <span class="principle__num" aria-hidden="true">0{i + 1}</span>
            </div>
            <h3 class="card__title">{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- CLIENTS / PROOF ---------- */}
  <section class="section section--alt">
    <div class="container">
      <header class="section-header section-header--center">
        <span class="eyebrow">Clients who trust our expertise</span>
        <h2>The numbers behind the work.</h2>
      </header>

      <div class="proof-metrics">
        {metrics.map((m) => (
          <div class="proof-metric">
            <span class="proof-metric__value" data-counter data-target={m.target}>
              <span class="proof-metric__num">{m.target}</span><span class="proof-metric__suffix">{m.suffix}</span>
            </span>
            <span class="proof-metric__label">{m.label}</span>
          </div>
        ))}
      </div>

      <ul class="client-wall" aria-label="A sample of brands we have worked with">
        {clients.map((c) => (
          <li class="client-wall__item">
            <img
              src={c.logo}
              alt={c.name}
              loading="lazy"
              decoding="async"
              width="120"
              height="120"
            />
          </li>
        ))}
      </ul>

      <p class="proof-note">
        Shiseido, Pierre Fabre, iFlytek, Camper, Into You and 55+ more international and
        Chinese brands across beauty, F&amp;B, fashion, automotive and technology.
      </p>
    </div>
  </section>

  {/* ---------- RECOGNITION ---------- */}
  <section class="section section--tight">
    <div class="container">
      <div class="recognition">
        <span class="eyebrow">Industry recognition</span>
        <h2>Invited speakers, recognised for our expertise.</h2>
        <p class="lead">
          Our team is regularly invited to speak at brand summits, platform conferences
          and chamber of commerce events across China, Europe and North America.
          <a href="/insights">Read our latest thinking.</a>
        </p>
      </div>
    </div>
  </section>

  {/* ---------- CLOSING CTA ---------- */}
  <section class="section section--dark cta cta-team">
    <div class="cta-team__bg" aria-hidden="true">
      <img
        src="/Images/team/team-photo.png"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="cta-team__overlay" aria-hidden="true"></div>

    <div class="container text-center cta-team__inner">
      <span class="eyebrow">Get in touch</span>
      <h2>Thinking about expanding your brand or business to China?</h2>
      <p class="lead cta__lead">
        Tell us where you are and where you want to go. A senior member of the team
        will reply within one working day.
      </p>
      <a href="/contact" class="btn btn--primary">Contact us</a>
    </div>
  </section>

  <script is:inline>
    (function () {
      const counters = document.querySelectorAll('[data-counter]');
      if (!counters.length) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      const animate = (numEl, target) => {
        const duration = 1600;
        const start = performance.now();
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          numEl.textContent = Math.round(target * eased).toString();
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          const target = parseInt(el.dataset.target, 10);
          const numEl = el.querySelector('.proof-metric__num');
          if (!Number.isFinite(target) || !numEl) return;
          numEl.textContent = '0';
          animate(numEl, target);
          observer.unobserve(el);
        });
      }, { threshold: 0.35 });

      counters.forEach((el) => observer.observe(el));
    })();
  </script>

</Layout>

<style>
  /* ---------- About hero with team photo background ---------- */
  .about-hero {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: var(--space-9) 0 var(--space-8);
  }
  .about-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .about-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .about-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.55) 55%, rgba(0, 0, 0, 0.8) 100%);
  }
  .about-hero__inner { position: relative; }

  .about-hero .hero__title {
    max-width: 920px;
    color: var(--bbg-white);
  }
  .about-hero .hero__lead {
    color: rgba(255, 255, 255, 0.9);
    max-width: 720px;
  }

  /* ---------- Why we exist: split with signature ---------- */
  .about-split {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: var(--space-7);
    align-items: center;
  }
  .about-split__copy { max-width: 62ch; }

  .about-signature {
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: var(--radius-md);
    padding: var(--space-6);
    border-left: 3px solid var(--bbg-blue);
  }
  .about-signature figure { margin: 0; }
  .about-signature img {
    display: block;
    width: 100%;
    height: auto;
    max-width: 360px;
    margin: 0 auto var(--space-4);
  }
  .about-signature figcaption {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: var(--space-4);
    border-top: 1px solid var(--bbg-border);
    text-align: center;
  }
  .about-signature figcaption strong {
    color: var(--bbg-ink);
    font-weight: 600;
    font-size: var(--fs-body);
  }
  .about-signature figcaption span {
    color: var(--bbg-text-muted);
    font-size: var(--fs-small);
  }

  @media (max-width: 1024px) {
    .about-split { grid-template-columns: 1fr; }
  }

  /* ---------- Team cards ---------- */
  .team-grid { gap: var(--space-6); }
  .team-card {
    background: var(--bbg-white);
    border: 1px solid var(--bbg-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .team-card:hover {
    transform: translateY(-4px);
    border-color: var(--bbg-blue);
    box-shadow: var(--shadow-md);
  }
  .team-card__photo {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bbg-surface);
  }
  .team-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 400ms var(--ease);
  }
  .team-card:hover .team-card__photo img { transform: scale(1.03); }

  .team-card__body { padding: var(--space-5) var(--space-6) var(--space-6); }
  .team-card__name {
    font-size: var(--fs-h3);
    margin-bottom: 2px;
    color: var(--bbg-ink);
  }
  .team-card__role {
    display: block;
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--bbg-blue);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 2px;
  }
  .team-card__base {
    display: block;
    font-size: var(--fs-small);
    color: var(--bbg-text-muted);
    margin-bottom: var(--space-4);
  }
  .team-card__body p {
    font-size: var(--fs-body);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .team-card__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-3);
  }
  .team-card__links a {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: var(--bbg-blue-light);
    color: var(--bbg-blue);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease), transform var(--dur) var(--ease);
  }
  .team-card__links a:hover {
    background: var(--bbg-blue);
    color: var(--bbg-white);
    transform: translateY(-2px);
  }
  .team-card__links svg { width: 16px; height: 16px; }

  /* ---------- Credentials ---------- */
  .credentials {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-5);
    grid-template-columns: none;
  }
  .credential {
    position: relative;
    overflow: hidden;
    isolation: isolate;
