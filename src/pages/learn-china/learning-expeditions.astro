---
import Layout from '../../layouts/Layout.astro';

const heroStats = [
  { value: '6 to 10', label: 'People per cohort. Small by design.' },
  { value: '3 to 5', label: 'Days on the ground, typically.' },
  { value: '20 yrs', label: 'Running operations inside the market.' },
];

const heroTags = [
  'eCommerce', 'Retail', 'Content', 'AI', 'Distribution', 'Platforms',
];

const contrastList = [
  { was: 'A business trip', is: 'A programme with a brief, an agenda and an outcome' },
  { was: 'A conference', is: 'Working sessions with the people who run the floor' },
  { was: 'A tour', is: 'Company visits, store walks and live operations you can question' },
  { was: 'A pitch deck', is: 'A custom plan you take back to the office' },
];

const formatIcon: Record<string, string> = {
  talk: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a8 8 0 0 1-12 7l-5 1 1-4a8 8 0 1 1 16-4z"/><line x1="8" y1="11" x2="16" y2="11"/><line x1="8" y1="14" x2="13" y2="14"/></svg>',
  building: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="9" x2="9" y2="21"/><line x1="15" y1="9" x2="15" y2="21"/></svg>',
  store: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 9 5 4h14l1 5"/><path d="M5 9v11h14V9"/><path d="M9 20v-6h6v6"/></svg>',
  tools: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a5 5 0 1 1-7.1 7.1L3 18v3h3l4.6-4.6a5 5 0 0 1 7.1-7.1z"/><line x1="17" y1="7" x2="21" y2="3"/></svg>',
  lantern: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0v6a6 6 0 0 1-12 0z"/><path d="M6 8h12"/><path d="M6 14h12"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/></svg>',
  users: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
};

const formats = [
  {
    icon: 'talk',
    label: 'Expert Dialogues',
    body: 'Sessions with platform account managers, brand operators, MCN leaders, content producers and technology executives. The room is in the room.',
    items: ['Platform account managers', 'Brand operators on the ground', 'MCN agency leaders', 'Technology executives', 'Marketing practitioners'],
  },
  {
    icon: 'building',
    label: 'Company Visits',
    body: 'Access to active operations, production facilities and AI-powered systems. Where possible, we walk the backend.',
    items: ['Platform operations centres', 'Content production studios', 'AI technology companies', 'MCN agencies', 'Fulfilment centres'],
  },
  {
    icon: 'store',
    label: 'Store Visits',
    body: 'Consumer behaviour, payment flows and retail technology observed live, not reported.',
    items: ['Flagship brand stores', 'New retail concepts', 'Smart retail formats', 'Shopping districts', 'O2O retail models'],
  },
  {
    icon: 'tools',
    label: 'Workshops',
    body: 'Apply what you have just seen to your category, your budget and your team. Structured, timed, output-focused.',
    items: ['Platform evaluation', 'Content strategy', 'Budget planning', 'AI assessment', 'Action planning'],
  },
  {
    icon: 'lantern',
    label: 'Cultural Context',
    body: 'Consumer culture, social dynamics and digital behaviour. The context behind the numbers is the reason the numbers land the way they do.',
    items: [],
  },
  {
    icon: 'users',
    label: 'Networking',
    body: 'Groups of 6 to 10 professionals across industries and markets. The other participants often become part of what you take home.',
    items: [],
  },
];

const whyDifferent = [
  {
    h: 'Led by practitioners',
    p: 'The people leading sessions manage client accounts and solve operational problems daily. That is why you see live operations instead of slide decks, get honest answers on what works, and meet the working partners behind the case studies.',
  },
  {
    h: 'Access to active operations',
    p: 'Where possible, you see backend systems from live operations, current campaign performance and real cost structures. This transparency is rare because most tour operators do not run their own operations.',
  },
  {
    h: 'Platform relationships',
    p: 'Our ongoing relationships with Douyin, Xiaohongshu, Tmall and others unlock access you cannot arrange on your own. Platform teams join because we work with them regularly.',
  },
  {
    h: 'Focused expertise',
    p: 'We specialise in eCommerce, retail, content, distribution and AI. We are not generalist China consultants. We are operators who use these platforms every day.',
  },
  {
    h: 'Reality over hype',
    p: 'You see what failed and why, not just the success stories. We tell you when something is not worth the investment. You leave with realistic expectations.',
  },
];

const personas = [
  { h: 'Executives planning China market entry', p: 'You are 6 to 18 months from launch and need to understand platform requirements, real costs and operational complexity.' },
  { h: 'eCommerce leaders evaluating platforms', p: 'You run digital commerce and need to see how Tmall, Douyin and Xiaohongshu actually work.' },
  { h: 'Marketing teams studying content commerce', p: 'You manage campaigns and want to understand livestream commerce and platform algorithms in practice.' },
  { h: 'Technology leaders evaluating AI', p: 'You lead digital transformation and need to see working AI systems, not vendor demos.' },
  { h: 'Agency partners advising on China', p: 'Your clients ask about China. You need firsthand knowledge to advise credibly.' },
  { h: 'Cross-functional teams', p: 'You are bringing marketing, operations and technology leaders together to align on strategy.' },
];

const trackIcon: Record<string, string> = {
  shop: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 8h14l-1 12H6z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/></svg>',
  cpu: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2M15 2v2M9 20v2M15 20v2M2 9h2M2 15h2M20 9h2M20 15h2"/></svg>',
};

const tracks = [
  {
    n: '01',
    icon: 'shop',
    title: 'eCommerce and digital',
    lead: 'Four days across Tmall, Douyin, new retail and fulfilment. Platforms, people and unit economics.',
    days: [
      {
        day: 'Day 1',
        blocks: [
          { h: 'Company visits', items: ['Tmall Global operations centre', 'A brand running cross-border stores'] },
          { h: 'Expert sessions', items: ['Platform account managers on platform mechanics', 'Brand operator on market entry realities'] },
        ],
      },
      {
        day: 'Day 2',
        blocks: [
          { h: 'Company visits', items: ['Douyin content production facility', 'MCN agency managing creators'] },
          { h: 'Store visits', items: ['Observe a live livestream commerce session'] },
          { h: 'Expert sessions', items: ['Content producers on platform requirements', 'MCN leader on creator partnerships'] },
        ],
      },
      {
        day: 'Day 3',
        blocks: [
          { h: 'Store visits', items: ['New retail formats (Hema, smart stores)', 'Shopping districts to observe consumer behaviour'] },
          { h: 'Expert sessions', items: ['Retail innovation leader on O2O', 'Digital media buyer on platform advertising'] },
        ],
      },
      {
        day: 'Day 4',
        blocks: [
          { h: 'Company visits', items: ['Logistics and fulfilment centre'] },
          { h: 'Expert sessions', items: ['Legal advisor on compliance', 'Operations manager on cost realities'] },
        ],
      },
    ],
  },
  {
    n: '02',
    icon: 'cpu',
    title: 'AI and technology',
    lead: 'Four days inside the systems shaping commerce, content, retail and logistics. Working AI, not vendor demos.',
    days: [
      {
        day: 'Day 1',
        blocks: [
          { h: 'Company visits', items: ['AI content production company', 'Marketing technology provider using AI'] },
          { h: 'Expert sessions', items: ['Technology executives on AI implementation', 'Content teams on automation tools'] },
        ],
      },
      {
        day: 'Day 2',
        blocks: [
          { h: 'Company visits', items: ['eCommerce company using AI recommendation systems', 'Customer service centre with AI chatbots'] },
          { h: 'Expert sessions', items: ['Technology leaders on AI in commerce', 'Operations managers on automation results'] },
        ],
      },
      {
        day: 'Day 3',
        blocks: [
          { h: 'Store visits', items: ['Automated retail stores', 'Smart stores using computer vision'] },
          { h: 'Company visits', items: ['Warehouse with robotics and automation'] },
          { h: 'Expert sessions', items: ['Retail technology innovators', 'Logistics AI specialists'] },
        ],
      },
      {
        day: 'Day 4',
        blocks: [
          { h: 'Expert sessions', items: ['Data analytics platforms demo', 'Privacy and compliance advisor on PIPL'] },
          { h: 'Workshop', items: ['AI strategy development', 'Key learnings and action plan'] },
        ],
      },
    ],
  },
];

const faqs = [
  { q: 'How do you customise expeditions?', a: 'We build each programme around your objectives, industry and what you need to understand. Some groups need deep focus on Douyin and content commerce. Others want full platform coverage. Many want to see AI in action. The visits, sessions and store walks are designed to match.' },
  { q: "What is the typical group size?", a: 'We keep groups small, 6 to 10 people maximum. That is what unlocks real access during company visits, meaningful interaction with experts and deeper workshop discussions.' },
  { q: 'Do I need to speak Chinese?', a: 'No. Professional interpretation is provided throughout, for every company visit, expert session, store walk and workshop.' },
  { q: 'Can we visit specific companies or platforms?', a: 'Yes. Tell us which companies or platforms you want to see and we arrange access where possible. Some visits depend on company availability and our relationships, but your learning objectives drive the programme.' },
  { q: 'What if we are not planning to enter China?', a: 'Many participants join to study models and technologies they can adapt to other markets. Chinese platforms and AI applications are often 2 to 3 years ahead in practical implementation. The insights travel.' },
  { q: 'Can we bring our agency or partners?', a: 'Yes. Many companies bring their agency teams or technology partners. It helps align everyone on what is realistic and what is possible.' },
  { q: 'How long are expeditions?', a: 'Typically 3 to 5 days depending on focus areas and depth. We can design shorter focused programmes (3 days on Douyin commerce) or longer ones of 5 to 8 days covering eCommerce, retail and AI.' },
  { q: 'Can you focus on our specific industry?', a: 'Yes. We tailor visits and sessions to your industry, whether beauty, fashion, automotive, food, luxury or pet care. You see relevant examples and meet operators in your sector.' },
  { q: 'What happens after the expedition?', a: 'You receive a detailed summary report, presentation materials, a contact directory and a post-expedition Q&A session. Many participants engage us afterwards for market entry, operations support or ongoing advisory. No obligation.' },
  { q: 'When is the best time to join?', a: 'Avoid Chinese New Year (late January to February), Golden Week (October 1 to 7) and major shopping festivals (618, Double 11). The best windows are March to May and September to November, when operations are running normally and platforms are not consumed by festival campaigns.' },
  { q: 'Which cities do expeditions visit?', a: 'Most programmes focus on Shanghai (eCommerce and platform HQs), Shenzhen (technology and AI) or Hangzhou (Alibaba ecosystem). If time allows, we can go deeper into Tier 3 and 4 cities to see different consumer behaviour, emerging market dynamics and how platforms operate beyond the major hubs.' },
];

const related = [
  { title: 'Masterclass', desc: 'A concentrated training programme on platforms, consumer behaviour and campaign mechanics. In-house, on-site or remote.', href: '/learn-china/masterclass' },
  { title: 'Platforms', desc: 'Tmall, JD, Douyin, WeChat, RED, Pinduoduo. The map of every major Chinese platform and who it is for.', href: '/learn-china/platforms' },
  { title: 'Insights', desc: 'Articles and analysis written by the people who run operations in the market every day.', href: '/insights' },
];
---

<Layout
  title="China Learning Expeditions | Beyond Border Group"
  description="Immersive 3 to 5 day learning expeditions in China focused on eCommerce, digital, retail, AI, content and distribution. Led by operators. Customised to your business objectives."
>

  {/* ---------- HERO ---------- */}
  <section class="hero-fullbleed le-hero">
    <picture>
      <source srcset="/Images/hero-livestream.webp" type="image/webp" />
      <img
        src="/Images/hero-livestream.jpg"
        alt="A livestream commerce studio at work in Shanghai"
        class="hero-fullbleed__image"
        width="1600"
        height="900"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-fullbleed__overlay le-hero__overlay" aria-hidden="true"></div>

    <div class="container hero-fullbleed__inner le-hero__inner">
      <div class="hero-fullbleed__copy le-hero__copy">
        <span class="eyebrow eyebrow--on-dark">Learn China / Learning Expeditions</span>
        <h1 class="hero-fullbleed__title">Fly to China and see the market yourself. Stores, platforms, operators, AI in the wild.</h1>
        <p class="hero-fullbleed__lead">
          Immersive programmes on eCommerce, digital, retail, AI, content and
          distribution. Customised to your business objectives, led by operators
          with 20 years running the market.
        </p>
        <div class="hero-fullbleed__actions">
          <a class="btn btn--primary" href="/contact">Plan an expedition</a>
          <a class="btn btn--ghost-light" href="#how">See how it works</a>
        </div>

        <ul class="le-hero__tags" aria-label="Focus areas">
          {heroTags.map(t => <li>{t}</li>)}
        </ul>
      </div>
    </div>
  </section>

  {/* ---------- STATS STRIP ---------- */}
  <section class="le-stats-strip">
    <div class="container">
      <ul class="le-stats">
        {heroStats.map(s => (
          <li class="le-stat">
            <span class="le-stat__value">{s.value}</span>
            <span class="le-stat__label">{s.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ---------- WHAT IT IS ---------- */}
  <section class="section section--alt">
    <div class="container">
      <div class="le-split">
        <div class="le-split__copy">
          <span class="eyebrow">What it is</span>
          <h2>Beyond a business trip. A programme with a brief, an agenda and an outcome.</h2>
          <p class="lead">
            A learning expedition is an intensive, immersive programme designed for
            executives and professionals to gain firsthand knowledge of a market,
            its technologies and its business practices.
          </p>
          <p>
            Unlike a traditional business trip or a conference, a learning
            expedition combines company visits, expert sessions, hands-on workshops
            and direct observation to give you a real understanding of how things
            work in practice.
          </p>
          <p>
            China is where the world's most advanced digital commerce and AI
            ecosystems are running at scale. Seeing platforms, technologies and
            strategies in action gives you insights you can apply to your own
            market, inform decisions about China entry, and spot innovations
            shaping the next phase of digital business globally.
          </p>
        </div>

        <aside class="le-contrast" aria-label="What a learning expedition is not">
          <span class="eyebrow">Not this, this</span>
          <ul class="le-contrast__list">
            {contrastList.map(c => (
              <li class="le-contrast__row">
                <span class="le-contrast__was">{c.was}</span>
                <span class="le-contrast__arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="13 6 19 12 13 18"/></svg>
                </span>
                <span class="le-contrast__is">{c.is}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  {/* ---------- HOW IT WORKS ---------- */}
  <section class="section" id="how">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">How it works</span>
        <h2>Six components, one programme, every day mapped to your objectives.</h2>
        <p class="lead">
          Each expedition combines expert dialogues, company visits, store walks,
          workshops, cultural context and networking. The mix is tuned to your
          industry, your level of China exposure and the questions your team
          needs to answer.
        </p>
      </header>

      <div class="le-formats">
        {formats.map(f => (
          <article class="le-format">
            <span class="le-format__icon" aria-hidden="true" set:html={formatIcon[f.icon]} />
            <h3 class="le-format__title">{f.label}</h3>
            <p class="le-format__body">{f.body}</p>
            {f.items.length > 0 && (
              <ul class="le-format__list">
                {f.items.map(i => <li>{i}</li>)}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- WHY DIFFERENT ---------- */}
  <section class="section section--alt">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Why this one</span>
        <h2>Not a tour. An operator-led programme.</h2>
        <p class="lead">
          Beyond Border Group manages active eCommerce operations, content
          campaigns and platform partnerships. That is what makes the difference
          between a scripted trip and a programme that answers your real questions.
        </p>
      </header>

      <div class="le-why">
        {whyDifferent.map((w, i) => (
          <article class="le-why__item">
            <span class="le-why__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="le-why__title">{w.h}</h3>
            <p>{w.p}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- PARTICIPANTS ---------- */}
  <section class="section">
    <div class="container">
      <header class="section-header section-header--center">
        <span class="eyebrow">Who joins</span>
        <h2>Executives, operators and agencies who need a real view of the market.</h2>
      </header>

      <div class="le-personas">
        {personas.map(p => (
          <article class="le-persona">
            <span class="le-persona__check" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div class="le-persona__body">
              <h3 class="le-persona__title">{p.h}</h3>
              <p>{p.p}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- ITINERARIES ---------- */}
  <section class="section section--alt" id="itineraries">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow">Sample itineraries</span>
        <h2>Two tracks you can run as is, or recombine to fit your brief.</h2>
        <p class="lead">
          Every expedition is custom. These two tracks show the shape of what a
          week on the ground looks like. Swap days, add days, or split them
          across two visits. The brief leads the itinerary.
        </p>
      </header>

      <div class="le-tracks">
        {tracks.map(t => (
          <article class="le-track">
            <div class="le-track__rail">
              <span class="le-track__icon" aria-hidden="true" set:html={trackIcon[t.icon]} />
              <span class="le-track__num">{t.n}</span>
            </div>

            <div class="le-track__content">
              <header class="le-track__header">
                <h3 class="le-track__title">{t.title}</h3>
                <p class="le-track__lead">{t.lead}</p>
              </header>

              <div class="le-track__days">
                {t.days.map(d => (
                  <div class="le-day">
                    <h4 class="le-day__title">{d.day}</h4>
                    <div class="le-day__blocks">
                      {d.blocks.map(b => (
                        <div class="le-block">
                          <span class="le-block__label">{b.h}</span>
                          <ul class="le-block__list">
                            {b.items.map(i => <li>{i}</li>)}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- FAQ ---------- */}
  <section class="section">
    <div class="container">
      <header class="section-header section-header--center">
        <span class="eyebrow">FAQ</span>
        <h2>Common questions about our China learning expeditions.</h2>
      </header>

      <div class="le-faq">
        {faqs.map(f => (
          <details class="le-faq__item">
            <summary class="le-faq__q">
              <span>{f.q}</span>
              <span class="le-faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </summary>
            <p class="le-faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- RELATED ---------- */}
  <section class="section section--alt">
    <div class="container">
      <header class="section-header section-header--split">
        <div>
          <span class="eyebrow">Keep going</span>
          <h2>More ways to learn the market.</h2>
        </div>
        <a href="/learn-china" class="btn btn--secondary btn--sm">All Learn China programmes</a>
      </header>

      <div class="grid grid-3">
        {related.map(r => (
          <a href={r.href} class="card le-related">
            <h3 class="card__title">{r.title}</h3>
            <p>{r.desc}</p>
            <span class="le-related__link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ---------- CLOSING CTA ---------- */}
  <section class="section section--dark cta">
    <div class="container text-center">
      <span class="eyebrow">Get in touch</span>
      <h2>Thinking about an expedition for your team?</h2>
      <p class="lead cta__lead">
        Tell us your brief, your industry and the cities you want to cover. We
        come back within one business day with a draft programme and a timeline.
      </p>
      <a href="/contact" class="btn btn--primary">Plan an expedition</a>
    </div>
  </section>

</Layout>

<style>
  /* ---------- Hero ---------- */
  .le-hero { min-height: clamp(560px, 80vh, 720px); }
  .le-hero__overlay {
    background: linear-gradient(
      105deg,
      rgba(10, 18, 28, 0.88) 0%,
      rgba(10, 18, 28, 0.72) 45%,
      rgba(10, 18, 28, 0.35) 100%
    );
  }
  .le-hero__inner {
    padding-top: clamp(128px, 17vh, 200px);
    padding-bottom: clamp(128px, 17vh, 200px);
    align-items: center;
  }
  .le-hero__copy { max-width: 760px; }
  .le-hero__copy .hero-fullbleed__title { max-width: 820px; }
  .le-hero__copy .hero-fullbleed__lead { max-width: 640px; }

  .le-hero__tags {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }
  .le-hero__tags li {
    font-size: var(--fs-small);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    padding: 6px 14px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* ---------- Stats strip ---------- */
  .le-stats-strip {
    background: var(--bbg-ink);
    color: var(--bbg-white);
    padding: var(--space-6) 0;
  }
  .le-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .le-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0 var(--space-5);
    border-left: 2px solid var(--bbg-blue);
  }
  .le-stat:first-child { padding-left: 0; border-left: 0; }
  .le-stat__value {
