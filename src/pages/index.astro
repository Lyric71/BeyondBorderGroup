  <script is:inline>
    document.querySelectorAll('.pillar-item__head').forEach((head) => {
      head.addEventListener('click', () => {
        const item = head.closest('.pillar-item');
        const parent = item.parentElement;
        parent.querySelectorAll('.pillar-item.is-open').forEach((open) => {
          if (open !== item) open.classList.remove('is-open');
        });
        item.classList.toggle('is-open');
      });
    });

    document.querySelectorAll('.svc-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const stage = tab.dataset.stage;
        document.querySelectorAll('.svc-tab').forEach((t) => {
          const on = t === tab;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        document.querySelectorAll('.svc-panel').forEach((p) => {
          p.classList.toggle('is-active', p.dataset.stage === stage);
        });
      });
    });
  </script>

