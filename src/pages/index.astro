const allCases = await getCollection('cases', ({ data }) => !data.draft);
const featuredCases = allCases
  .slice()
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const allInsights = await getCollection('insights', ({ data }) => !data.draft);
const latestInsights = allInsights
  .slice()
  .sort((a, b) => {
    const da = a.data.pubDate?.valueOf() ?? 0;
    const db = b.data.pubDate?.valueOf() ?? 0;
    return db - da;
  })
  .slice(0, 3);

function readingTime(body: string | undefined) {
  if (!body) return '';
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.round(words / 200))} min read`;
}

function formatInsightDate(d?: Date) {
  if (!d) return '';
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

---

<Layout
  title="BeyondBorderGroup | China Market Entry, eCommerce & Distribution"
  description="We help global brands enter China, grow sales on Tmall, JD, Douyin, WeChat and RED, and find the right distributor. Shanghai, Hong Kong, Paris."
>

  {/* ---------- HERO ---------- */}
  <section class="hero-fullbleed">
    <picture>
      <source srcset="/Images/hero-livestream.webp" type="image/webp" />
      <img
        src="/Images/hero-livestream.jpg"
        alt=""
        class="hero-fullbleed__image"
        width="1376"
        height="768"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
    <div class="hero-fullbleed__overlay" aria-hidden="true"></div>

    <div class="container hero-fullbleed__inner">
      <div class="hero-fullbleed__copy">
        <span class="eyebrow eyebrow--on-dark">China market entry, eCommerce & distribution</span>
        <h1 class="hero-fullbleed__title">Sell in China. Grow in China. Understand China.</h1>
        <p class="hero-fullbleed__lead">
          Cross-border eCommerce, social commerce, distribution and market entry consulting.
          One team, three offices.
        </p>
        <div class="hero-fullbleed__actions">
          <a class="btn btn--primary" href="/contact">Talk to us</a>
          <a class="btn btn--ghost-light" href="/work">See our work</a>
        </div>
      </div>

      {heroStats.map((s) => (
        <div class="hero-fullbleed__stat">
          <div class="hero-stat__value">{s.value}</div>
          <div class="hero-stat__label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  {/* ---------- PILLARS: ACCORDION ---------- */}
  <section class="section section--alt">
    <div class="container">
      <div class="pillars-intro">
        <span class="eyebrow">Where to start</span>
        <h2>China is not one problem to solve</h2>
        <ul class="pillar-list">
          {pillars.map((p) => (
            <li class="pillar-item">
              <div class="pillar-item__head">
                <h3 class="pillar-item__title">{p.title}</h3>
                <span class="pillar-item__chev" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
                </span>
              </div>
              <div class="pillar-item__body">
                <p class="pillar-item__lead">{p.lead}</p>
                {p.paragraphs.map((par) => <p class="pillar-item__para">{par}</p>)}
                <ul class="pillar-item__tactics">
                  {p.tactics.map((t) => <li>{t}</li>)}
                </ul>
                <p class="pillar-item__close">{p.close}</p>
                <a href={p.href} class="btn btn--ghost">{p.title}</a>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* ---------- DAY IN CHINESE COMMERCE ---------- */}
  <section class="section day-timeline-section">
    <div class="container">
      <header class="section-header section-header--center">
        <span class="eyebrow">A day in Chinese commerce</span>
        <h2>Your brand, every moment of the day</h2>
        <p class="section-header__lead">
          Chinese consumers move across platforms from morning to night.
          Each one has its own rules, content formats, and commercial logic.
        </p>
      </header>

      <ol class="day-timeline" aria-label="A day with Chinese consumer platforms">
        {dayStops.map((s) => (
          <li class="day-stop">
            <figure class="day-stop__photo">
              <img src={s.photo} alt="" loading="lazy" decoding="async" />
            </figure>
            <div class="day-stop__info">
              <span class="day-stop__time">{s.time}</span>
              <span class="day-stop__moment">{s.moment}</span>
              <span class="day-stop__platform">
                <img class="day-stop__logo" src={s.logo} alt="" loading="lazy" decoding="async" />
                <span class="day-stop__platform-text">
                  <span class="day-stop__name">{s.name}</span>
                  <span class="day-stop__zh">{s.zh}</span>
                </span>
              </span>
            </div>
          </li>
        ))}
      </ol>

      <div class="day-timeline__cta">
        <a href="#services" class="btn btn--primary">Discover our services</a>
        <p class="day-timeline__cta-note">
          The playbook changes by platform. See how we help brands show up on each one.
        </p>
      </div>
    </div>
  </section>

  {/* ---------- SERVICES BY STAGE (TABBED) ---------- */}
  <section class="section" id="services">
    <div class="container">
      <header class="section-header section-header--center">
        <span class="eyebrow">Services</span>
        <h2>Every service you need, at every stage</h2>
      </header>

      <div class="svc-tabs" role="tablist" aria-label="Services by stage">
        {servicesByStage.map((stage, i) => (
          <button
            type="button"
            role="tab"
            class={`svc-tab${i === 0 ? ' is-active' : ''}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`svc-panel-${stage.key}`}
            data-stage={stage.key}
            id={`svc-tab-${stage.key}`}
          >
            {stage.label}
          </button>
        ))}
      </div>

      {servicesByStage.map((stage, i) => (
        <div
          class={`svc-panel${i === 0 ? ' is-active' : ''}`}
          role="tabpanel"
          id={`svc-panel-${stage.key}`}
          aria-labelledby={`svc-tab-${stage.key}`}
          data-stage={stage.key}
        >
          <p class="svc-panel__intro">{stage.intro}</p>

          <div class="services-grid">
            {stage.services.map((s) => (
              <article class="service-card">
                <div class="service-card__head">
                  <span class="service-icon" aria-hidden="true" set:html={svcIcon[s.icon]} />
                  <div class="service-card__heading">
                    <h3 class="service-card__title">{s.title}</h3>
                  </div>
                </div>
                <p class="service-card__body">{s.desc}</p>

                <div class="svc-checklist">
                  <span class="svc-checklist__title">What you get</span>
                  <ul>
                    {s.bullets.map((b) => <li>{b}</li>)}
                  </ul>
