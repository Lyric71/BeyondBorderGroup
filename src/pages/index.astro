---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="hero">
		<div class="container">
			<span class="hero__eyebrow">Beyond Border Group</span>
			<h1 class="hero__title">Marketing & eCommerce, built for China.</h1>
			<p class="hero__lead">
				A cross-border agency with teams in Shanghai, Hong Kong, and Paris,
				helping international brands grow on Tmall, JD, Douyin, WeChat, and
				Xiaohongshu.
			</p>
			<div class="hero__actions">
				<a class="btn btn--primary" href="#contact">Start a project</a>
				<a class="btn btn--ghost" href="#work">See our work</a>
			</div>
		</div>
	</section>
</Layout>
